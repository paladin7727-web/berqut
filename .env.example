# Contact form email delivery (Resend — https://resend.com)
#
# Setup:
#   1. Create a free account at resend.com
#   2. Create an API key (Dashboard → API Keys) and paste it below
#   3. Copy this file to `.env.local` for local dev (never commit .env.local)
#   4. For production, add RESEND_API_KEY in the Vercel dashboard
#      (Project → Settings → Environment Variables), then redeploy
#
# Required:
RESEND_API_KEY=

# Optional overrides (sensible defaults are used if left unset):
#
# Where enquiries are delivered. Defaults to Roberts@berqut.com
# CONTACT_TO_EMAIL=Roberts@berqut.com
#
# The "from" address. Defaults to Resend's shared onboarding sender, which
# works immediately with no domain setup. Once berqut.com is verified in
# Resend (Dashboard → Domains), change this to e.g. "BERQUT <noreply@berqut.com>"
# so emails send from your own domain and land in inboxes reliably.
# CONTACT_FROM_EMAIL=BERQUT Website <onboarding@resend.dev>
